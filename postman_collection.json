{
  "info": {
    "_postman_id": "library-auth-collection",
    "name": "Library Management - Auth API",
    "description": "Collection pour tester le système d'authentification et gestion d'utilisateurs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"confirmPassword\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "register"]
            },
            "description": "Créer un nouvel utilisateur"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "login"]
            },
            "description": "Se connecter (retorne un JWT token)"
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE",
                "description": "Remplacer YOUR_TOKEN_HERE par le token reçu lors du login"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "auth", "profile"]
            },
            "description": "Récupérer le profil de l'utilisateur connecté"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Users Management",
      "item": [
        {
          "name": "Get All Users (Admin Only)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN_HERE",
                "description": "Token d'un utilisateur ADMIN"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "users"]
            },
            "description": "Récupérer tous les utilisateurs (admin seulement)"
          },
          "response": []
        },
        {
          "name": "Get User by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "users", "1"]
            },
            "description": "Récupérer un utilisateur par son ID"
          },
          "response": []
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_TOKEN_HERE"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nom\": \"Jane Doe\",\n  \"email\": \"jane@example.com\"\n}"
            },
            "url": {
              "raw": "http://localhost:3001/api/users/1",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "users", "1"]
            },
            "description": "Mettre à jour un utilisateur (soi-même ou admin peut changer le rôle)"
          },
          "response": []
        },
        {
          "name": "Delete User (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer YOUR_ADMIN_TOKEN_HERE"
              }
            ],
            "url": {
              "raw": "http://localhost:3001/api/users/2",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3001",
              "path": ["api", "users", "2"]
            },
            "description": "Supprimer un utilisateur (admin seulement)"
          },
          "response": []
        }
      ]
    }
  ]
}

{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": [
      "warn",
      {
        "allow": [
          "warn",
          "error",
          "log"
        ]
      }
    ],
    "consistent-return": "warn",
    "no-param-reassign": [
      "error",
      {
        "props": false
      }
    ],
    "no-unused-vars": [
      "warn",
      {
        "argsIgnorePattern": "^_"
      }
    ],
    "func-names": "off"
  },
  "overrides": [
    {
      "files": [
        "**/__tests__/**/*.js",
        "**/?(*.)+(spec|test).js"
      ],
      "env": {
        "jest": true
      }
    }
  ]
}

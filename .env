# PostgreSQL Connection
POSTGRES_USER=libraryuser
POSTGRES_PASSWORD=librarypassword
POSTGRES_DB=library_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5433

# Application
NODE_ENV=development
PORT=3001

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Logging
LOG_LEVEL=info

# ============================================
# Service Ports (host-side)
# Change these if a port is already in use
# ============================================

# PostgreSQL host port (maps to container 5432)
POSTGRES_HOST_PORT=5433

# App API host port
APP_HOST_PORT=3001

# Prometheus host port (maps to container 9090)
PROMETHEUS_HOST_PORT=9091

# Grafana host port (maps to container 3000)
GRAFANA_HOST_PORT=3002

# Node Exporter host port (maps to container 9100)
NODE_EXPORTER_HOST_PORT=9101

# Alertmanager host port (maps to container 9093)
ALERTMANAGER_HOST_PORT=9093

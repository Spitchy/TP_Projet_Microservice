{
  "name": "library-management-microservice",
  "version": "1.0.0",
  "description": "A Library Management Microservice built with Express.js and PostgreSQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint src --ext .js --fix",
    "test": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --coverageReporters=text --coverageReporters=json",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:ci": "cross-env NODE_ENV=test jest --coverage --ci --forceExit"
  },
  "keywords": [
    "library",
    "microservice",
    "express",
    "postgresql"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.0",
    "pg": "^8.10.0",
    "sequelize": "^6.33.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.20",
    "supertest": "^6.3.3"
  }
}
